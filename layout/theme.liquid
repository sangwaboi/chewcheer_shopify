<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ page_description | default: 'ChewCheer — prebiotic chew sticks for your dog''s gut health and well-being.' }}">

  <link rel="icon" type="image/jpeg" href="{{ 'favicon.jpg' | asset_url }}">
  <link rel="shortcut icon" type="image/jpeg" href="{{ 'favicon.jpg' | asset_url }}">
  <link rel="apple-touch-icon" href="{{ 'favicon.jpg' | asset_url }}">

  <title>
    {%- if page_title -%}{{ page_title }} | {{ shop.name }}{%- else -%}{{ shop.name }}{%- endif -%}
  </title>

  <link href="https://fonts.googleapis.com/css2?family=Spinnaker&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>
<body>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-[9999] focus:bg-white focus:px-4 focus:py-2">
    Skip to content
  </a>

  {%- if template.name == 'index' -%}
    <div class="relative min-w-0 overflow-x-clip">
      <div class="absolute top-0 left-0 w-full -z-10 min-w-0">
        {% render 'svg-hero-background' %}
      </div>
      <div class="absolute w-[200px]">
        <img src="{{ 'paw-green.png' | asset_url }}" alt="" class="absolute translate-x-60 translate-y-110 rotate-[-17deg] -z-100">
      </div>
      <div class="sticky top-0 z-50">
        {% render 'countdown-banner' %}
        {% render 'header-nav' %}
      </div>
      <main id="main-content">
        {{ content_for_layout }}
      </main>
    </div>
  {%- else -%}
    <main id="main-content">
      {{ content_for_layout }}
    </main>
  {%- endif -%}

  {% render 'milo-chat-widget' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
