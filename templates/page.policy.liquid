<div class="min-h-screen bg-[#f9f6f0] text-[#3d2b1f]">
  <header class="border-b border-[#4F815E]/30 bg-[#4F815E]/90 px-4 py-3 backdrop-blur-sm">
    <div class="mx-auto flex max-w-3xl items-center justify-between gap-4">
      <a href="/" class="font-[Talina] text-lg tracking-wide text-white md:text-xl no-underline">
        ChewCheer
      </a>
      <a
        href="/"
        class="shrink-0 font-[Spinnaker] text-sm text-white/95 underline-offset-4 hover:underline no-underline"
      >
        ← Back to home
      </a>
    </div>
  </header>
  <main class="mx-auto max-w-3xl px-4 py-10 pb-20">
    <h1 class="mb-8 font-[Talina] text-3xl leading-tight text-[#4F815E] md:text-4xl">{{ page.title }}</h1>
    <div class="space-y-6 font-[Spinnaker] text-sm leading-relaxed text-gray-800 md:text-[15px] [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:font-[Talina] [&_h2]:text-xl [&_h2]:text-[#4F815E] md:[&_h2]:text-2xl [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-5">
      {{ page.content }}
    </div>
  </main>
</div>
