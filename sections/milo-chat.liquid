<section class="w-full min-w-0 bg-[#F5F5F5] font-[Spinnaker]">
  <div class="relative w-full">
    <div class="absolute inset-0 bg-[#E5C687]"></div>

    <div class="relative z-10 max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 items-center mt-5 mb-5">
      {%- comment -%} LEFT: Got questions? {%- endcomment -%}
      <div class="relative -z-10">
        <div class="absolute top-1/2 left-1/2 -translate-x-[-330px] -translate-y-1/2 w-[400px] h-[400px] rotate-[-5deg] pointer-events-none">
          <img src="{{ 'paw-brown.png' | asset_url }}" alt="">
        </div>

        <h2 class="text-4xl md:text-5xl font-[Talina] font-bold text-brand-dark leading-tight tracking-wider">
          Got questions?
          <br>
          Milo got answers
        </h2>

        <p class="mt-5 font-[Cookie] text-lg md:text-xl text-[#4F815E] leading-relaxed max-w-sm text-wrap">
          No question is too small... from poop worries to
          picky eaters.
        </p>
        <p class="font-[Cookie] text-lg md:text-xl text-[#4F815E]">
          Ask away.
        </p>
      </div>

      {%- comment -%} RIGHT: Chat Widget {%- endcomment -%}
      <div class="flex justify-center md:justify-end">
        <div class="w-full max-w-[340px] bg-white rounded-2xl shadow-2xl border-3 border-[#4F815E] overflow-hidden">
          <div class="px-5 py-4 flex items-center gap-3 border-b border-gray-100">
            <div class="w-10 h-10 rounded-full bg-[#EAD9B5] flex items-center justify-center text-xl">
              <img src="{{ 'milo-avatar.png' | asset_url }}" alt="Milo">
            </div>
            <div class="flex items-center gap-2">
              <span class="font-extrabold text-lg text-brand-dark">Milo</span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#4F815E]"></span>
            </div>
          </div>

          <div class="px-5 py-4">
            <div class="bg-[#E8F0DC] border border-[#4F815E]/30 rounded-2xl rounded-tl-md px-4 py-3 max-w-[85%]">
              <p class="text-sm text-brand-dark leading-relaxed">
                Hey! What's up with your dog today?
              </p>
            </div>
          </div>

          <div class="px-5 pb-4">
            <div class="flex items-center gap-2 border border-gray-300 rounded-full px-4 py-2">
              <input
                type="text"
                placeholder="How long before result?"
                class="flex-1 text-sm outline-none bg-transparent text-gray-700 placeholder-gray-400"
              >
              <button class="flex items-center gap-1.5 bg-[#4F815E] hover:bg-[#3d6a4a] text-white text-sm font-semibold px-4 py-1.5 rounded-full transition-colors cursor-pointer">
                Send
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>
            </div>
          </div>

          <div class="px-5 pb-5">
            <ul class="space-y-1">
              {%- assign suggestions = "How long before result?|Can I give it daily?|How long before result?" | split: "|" -%}
              {%- for s in suggestions -%}
                <li class="text-xs text-gray-500 flex items-center gap-2 cursor-pointer hover:text-[#4F815E] transition-colors">
                  <span class="text-gray-400">•</span>
                  {{ s }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} CHEWCHEER large text banner {%- endcomment -%}
  <div class="relative w-full overflow-hidden py-4">
    <div
      class="text-center font-[Talina] font-black tracking-[0.15em] leading-none select-none chewcheer-gradient-text"
      style="font-size: clamp(80px, 12vw, 200px); background: linear-gradient(180deg, rgba(79, 129, 94, 0.05) 0%, rgba(79, 129, 94, 0.3) 30%, #4F815E 60%, #4F815E 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
    >
      CHEWCHEER
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Milo Chat + Banner",
  "settings": [],
  "presets": [
    {
      "name": "Milo Chat + Banner"
    }
  ]
}
{% endschema %}
